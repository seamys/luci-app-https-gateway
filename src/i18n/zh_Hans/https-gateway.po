msgid "Running"
msgstr "运行中"

msgid "Stopped"
msgstr "未运行"

msgid "Valid"
msgstr "有效"

msgid "Pending"
msgstr "待申请"

msgid "Unknown"
msgstr "未知"

msgid "No certificates configured"
msgstr "未配置任何证书"

msgid "nginx Status"
msgstr "nginx 状态"

msgid "Proxy Rules"
msgstr "代理规则数"

msgid "Certificate Status"
msgstr "证书状态"

msgid "Domain"
msgstr "域名"

msgid "Status"
msgstr "状态"

msgid "Expires"
msgstr "过期时间"

msgid "Key Type"
msgstr "密钥类型"

msgid "nginx configuration test passed"
msgstr "nginx 配置检查通过"

msgid "nginx configuration error: "
msgstr "nginx 配置错误: "

msgid "Test nginx Config"
msgstr "测试 nginx 配置"

msgid "Issue/renew all certificates? This may take 3-5 minutes."
msgstr "确认申请/续签所有证书？此操作可能需要 3-5 分钟。"

msgid "Certificate issuance started..."
msgstr "证书申请已启动..."

msgid "Issuing certificates..."
msgstr "证书申请中..."

msgid "Certificate issuance completed."
msgstr "证书申请完成。"

msgid "Issue/Renew Certificates"
msgstr "申请/续签证书"

msgid "Configuration reloaded"
msgstr "配置已重新加载"

msgid "Reload Configuration"
msgstr "重载配置"

msgid "HTTPS Gateway - Global Settings"
msgstr "HTTPS Gateway - 全局设置"

msgid "LAN HTTPS reverse proxy gateway — manage ACME certificates, nginx virtual hosts, and local DNS resolution in one place."
msgstr "局域网 HTTPS 反向代理网关 - 统一管理证书申请、nginx 虚拟主机、本地 DNS 解析。"

msgid "General Settings"
msgstr "基本设置"

msgid "Service Status"
msgstr "服务状态"

msgid "Enable Gateway"
msgstr "启用网关"

msgid "When disabled, the proxy service stops and uhttpd reverts to default ports."
msgstr "关闭后将停止代理服务，恢复 uhttpd 默认端口。"

msgid "ACME Email"
msgstr "ACME 邮箱"

msgid "Let's Encrypt account email for certificate expiry notifications."
msgstr "Let's Encrypt 账户邮箱，用于证书到期通知。"

msgid "DNS Provider"
msgstr "DNS 提供商"

msgid "DNS API provider used for DNS-01 challenge validation."
msgstr "用于 DNS-01 验证的 DNS API 提供商。"

msgid "Alibaba Cloud DNS (dns_ali)"
msgstr "阿里云 DNS (dns_ali)"

msgid "Cloudflare (dns_cf)"
msgstr "Cloudflare (dns_cf)"

msgid "Tencent DNSPod (dns_dp)"
msgstr "腾讯云 DNSPod (dns_dp)"

msgid "GoDaddy (dns_gd)"
msgstr "GoDaddy (dns_gd)"

msgid "DNS API Credentials"
msgstr "DNS API 凭证"

msgid "Format: Key=\"Value\". Example: Ali_Key=\"LTAI...\", Ali_Secret=\"...\""
msgstr "格式: Key=\"Value\"。例如 Ali_Key=\"LTAI...\"、Ali_Secret=\"...\""

msgid "DNS Propagation Wait (seconds)"
msgstr "DNS 传播等待（秒）"

msgid "Time to wait for DNS TXT record propagation. Recommended: 180-300."
msgstr "DNS TXT 记录传播等待时间，建议 180-300。"

msgid "Use Staging Environment"
msgstr "使用测试环境"

msgid "Use Let's Encrypt Staging for testing. Certificates will not be trusted by browsers."
msgstr "开启后使用 Let's Encrypt Staging 环境，调试用（证书不被浏览器信任）。"

msgid "Automatic Local DNS"
msgstr "自动管理本地 DNS"

msgid "Automatically add domain to router IP mappings in dnsmasq."
msgstr "自动在 dnsmasq 中添加域名到路由器 IP 的解析记录。"

msgid "HTTPS Gateway - Certificates"
msgstr "HTTPS Gateway - 证书管理"

msgid "Manage TLS certificates. Supports individual domains and wildcards (*.example.com). A wildcard certificate covers all subdomains without individual issuance."
msgstr "管理 TLS 证书。支持独立域名和泛域名 (*.example.com)。泛域名证书可覆盖所有子域名，无需逐个申请。"

msgid "Certificate List"
msgstr "证书列表"

msgid "Add Certificate"
msgstr "添加证书"

msgid "Enabled"
msgstr "启用"

msgid "Enter a full domain (e.g. nas.example.com) or wildcard (e.g. *.example.com). Wildcard certificates also cover the base domain."
msgstr "填写完整域名（如 nas.example.com）或泛域名（如 *.example.com）。泛域名证书会同时覆盖根域名。"

msgid "Domain cannot be empty"
msgstr "域名不能为空"

msgid "Invalid domain format. Example: sub.example.com or *.example.com"
msgstr "域名格式无效，例如: sub.example.com 或 *.example.com"

msgid "EC 256 is faster and smaller; RSA 2048 has better compatibility."
msgstr "EC 256 更快更小，RSA 2048 兼容性更好。"

msgid "EC 256 (Recommended)"
msgstr "EC 256（推荐）"

msgid "HTTPS Gateway - Proxy Rules"
msgstr "HTTPS Gateway - 代理规则"

msgid "Configure reverse proxy rules. Each rule maps a domain + path to a backend service, with HTTP and WebSocket support."
msgstr "配置反向代理规则。每条规则将域名+路径映射到后端服务，支持 HTTP 和 WebSocket。"

msgid "Add Proxy Rule"
msgstr "添加代理规则"

msgid "Name"
msgstr "名称"

msgid "A friendly name for this rule, e.g. \"NAS WebUI\", \"Home Assistant\"."
msgstr "便于识别的规则名称，如 \"NAS WebUI\"、\"Home Assistant\"。"

msgid "Domain for this rule (must be covered by a configured certificate)."
msgstr "此规则使用的域名（必须有对应的证书覆盖）。"

msgid "Enter a valid domain (no wildcards), e.g. nas.example.com"
msgstr "请输入有效域名（不含通配符），如: nas.example.com"

msgid "Path"
msgstr "路径"

msgid "URL path prefix, e.g. / or /api/. Paths under the same domain must be unique."
msgstr "URL 路径前缀，如 / 或 /api/。同域名下路径不能重复。"

msgid "Path must start with / and contain only letters, digits, _, ., -, /"
msgstr "路径必须以 / 开头，只能包含字母、数字、_、.、-、/"

msgid "Upstream"
msgstr "后端地址"

msgid "Backend service address, e.g. http://192.168.0.100:5000 or http://127.0.0.1:8080"
msgstr "目标服务的完整地址，如 http://192.168.0.100:5000 或 http://127.0.0.1:8080"

msgid "Upstream address cannot be empty"
msgstr "后端地址不能为空"

msgid "Enter a valid HTTP/HTTPS address"
msgstr "请输入有效的 HTTP/HTTPS 地址"

msgid "WebSocket"
msgstr "WebSocket"

msgid "Enable Upgrade/Connection headers for WebSocket long-lived connections."
msgstr "开启后添加 Upgrade/Connection 头，支持 WebSocket 长连接。"
